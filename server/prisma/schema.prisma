generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model bookings {
  id                       String    @id @db.VarChar(50)
  guest_name               String    @db.VarChar(150)
  adults                   Int
  children                 Int       @default(0)
  total_guests             Int
  yacht_id                 String?   @db.VarChar(50)
  start_date               DateTime  @db.Timestamptz(6)
  end_date                 DateTime  @db.Timestamptz(6)
  duration_hours           Decimal   @db.Decimal
  offered_hourly_rate      Decimal?  @db.Decimal
  catering_enabled         Boolean   @default(false)
  external_service_charges Decimal   @default(0) @db.Decimal
  decoration_charges       Decimal   @default(0) @db.Decimal
  water_slide_charges      Decimal   @default(0) @db.Decimal
  jet_ski_charges          Decimal   @default(0) @db.Decimal
  catering_charges         Decimal   @default(0) @db.Decimal
  other_charges            Decimal   @default(0) @db.Decimal
  subtotal                 Decimal   @db.Decimal
  vat_rate                 Decimal   @default(0) @db.Decimal
  vat_amount               Decimal   @default(0) @db.Decimal
  total_amount             Decimal   @db.Decimal
  payment_mode             String    @db.VarChar(50)
  payment_amount           Decimal   @default(0) @db.Decimal
  status                   String    @default("Pending") @db.VarChar(50)
  sales_person             String    @db.VarChar(100)
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  actual_adults            Int?
  actual_children          Int?      @default(0)
  actual_total_guests      Int?
  payment_collected_by     String?   @db.VarChar(50)
  boarding_status          String    @default("Scheduled") @db.VarChar(50)
  guest_email              String?   @db.VarChar(150)
  phone_number             String?   @db.VarChar(50)
  remarks                  String?   @db.Text
  yachts                   yachts?   @relation(fields: [yacht_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model system_defaults {
  key   String @id @db.VarChar(50)
  value String @db.Text
}

model users {
  id          String  @id @db.VarChar(50)
  name        String  @unique @db.VarChar(100)
  email       String  @unique @db.VarChar(255)
  type        String  @db.VarChar(50)
  designation String  @db.VarChar(50)
  role        String  @db.VarChar(50)
  active      Boolean @default(true)
  password    String  @db.VarChar(255)
  sessions    sessions[]
}

model sessions {
  id         String   @id @db.VarChar(255)
  user_id    String   @db.VarChar(50)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model yachts {
  id          String     @id @db.VarChar(50)
  name        String     @unique @db.VarChar(100)
  capacity    Int
  hourly_rate Decimal    @db.Decimal
  description String?
  bookings    bookings[]
}
